# --------------------------------------------------------------------
# JOBCOIN ($JOB) — the machine. Config template. Copy to .env and fill in.
#
# Every CYCLE_INTERVAL_SECONDS the bot:
#   1. Claims pump.fun creator fees (SOL) on the TREASURY (dev) wallet
#   2. Buys McDonald's stock (MCDx) on Jupiter with the spendable share of the
#      claim  (MCDx = the Backed/xStocks tokenized McDonald's share on Solana)
#   3. Snapshots holders and keeps wallets holding >= MIN_HOLDER_BALANCE $JOB
#   4. Airdrops the MCDx to EVERY qualified holder, PROPORTIONAL to how much
#      $JOB they hold — straight into their wallet. No claiming, automatic.
#
# Payout routing: each batch of holders is paid through a FRESH, bot-generated
# relay wallet. The relay's temporary MCDx account is opened and closed inside
# the SAME atomic transaction (treasury -> relay -> holders -> relay closes), so
# its rent round-trips and no single wallet is the on-chain parent of all
# holders.
#
# Safety: the bot can only ever SPEND SOL it has provably CLAIMED (the
# claimPoolLamports ledger, reconciled to the real measured balance delta each
# cycle). The dev's principal is never touched.
# --------------------------------------------------------------------

# --- Solana RPC (REQUIRED) ---
# Use a paid RPC (Helius / QuickNode / Triton). Free RPCs disable
# getProgramAccounts, which is required to snapshot $JOB holders.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# --- Wallets ---
# The ONLY key you provide. The TREASURY (dev) wallet owns the pump.fun $JOB
# token, receives creator fees, buys the MCDx, and funds the airdrop. Every
# relay wallet is generated by the bot at runtime — you never supply or store a
# "hot wallet" key.
CREATOR_WALLET_PRIVATE_KEY=PASTE_DEV_WALLET_PRIVATE_KEY

# Optional marketing slice: keep MARKETING_PERCENT of each claim back on the
# treasury (held, never auto-sent — withdraw manually). 0 = 100% buys stock.
# MARKETING_WALLET=
MARKETING_PERCENT=0

# --- Token ($JOB, your pump.fun coin) ---
# auto = watch the treasury wallet and adopt the next pump.fun token it launches.
# Once $JOB is live you can hardcode the mint here.
JOB_MINT=auto
MINT_WATCH_POLL_SECONDS=20

# --- The stock we hand out (McDonald's) ---
# Defaults to the verified MCDx mint; only change if you ever repoint the bot.
STOCK_MINT=XsqE9cRRpzxcGKDXj1BJ7Xmg4GRhZoyY1KpmGSxAWT2
STOCK_SYMBOL=MCDx
STOCK_TICKER=MCD
STOCK_NAME=McDonald's
STOCK_DECIMALS=8

# --- PumpPortal (optional) ---
# Lightning API key for server-side claim signing. Leave blank for local
# signing (works the same; signs in this process).
PUMPPORTAL_API_KEY=

# --- Jupiter (the SOL -> MCDx swap) ---
JUPITER_BASE_URL=https://lite-api.jup.ag
SWAP_SLIPPAGE_BPS=150              # 150 = 1.5% slippage tolerance on the buy

# --- The mechanic ---
CYCLE_INTERVAL_SECONDS=300         # 300 = 5 minutes between airdrops
MIN_HOLDER_BALANCE=500000          # must hold >= this many $JOB to qualify
RESERVE_PERCENT=10                 # keep 10% of every claim back as SOL buffer
MIN_DISPENSE_SOL=0.02              # skip the cycle if the spendable pool < this
MAX_RECIPIENTS_PER_CYCLE=600       # safety cap on recipients per cycle (largest first)
PAYOUT_BATCH_SIZE=6                # holders per tx/relay (max 10 with ATA creation)
PRIORITY_FEE=0.0005                # base SOL priority fee (escalates on retry)
ATA_RENT_ESTIMATE_SOL=0.0023       # pre-swap reserve per NEW holder MCDx account

# --- State persistence ---
# DATABASE_URL: a Postgres connection string. When set, the full dashboard
# state is snapshotted to Postgres so ALL lifetime numbers survive redeploys.
# On Railway: add a Postgres database and set DATABASE_URL=${{Postgres.DATABASE_URL}}
# If unset, the app falls back to the local JSON file (ephemeral on Railway).
# DATABASE_URL=
# STATE_DIR=/data

# --- Dashboard ---
PORT=3000
LOG_LEVEL=info
